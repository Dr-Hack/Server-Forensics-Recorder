#!/usr/bin/env bash
set -Eeuo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
    SOURCE_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd -P)"
    SOURCE_TARGET="$(readlink "$SOURCE_PATH")"
    if [[ "$SOURCE_TARGET" == /* ]]; then
        SOURCE_PATH="$SOURCE_TARGET"
    else
        SOURCE_PATH="${SOURCE_DIR}/${SOURCE_TARGET}"
    fi
done

SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd -P)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"
# shellcheck source=../lib/utils.sh
source "${ROOT_DIR}/lib/utils.sh"
load_config
# shellcheck source=../lib/logging.sh
source "${ROOT_DIR}/lib/logging.sh"
# shellcheck source=../lib/plugins.sh
source "${ROOT_DIR}/lib/plugins.sh"
# shellcheck source=../lib/metrics.sh
source "${ROOT_DIR}/lib/metrics.sh"
# shellcheck source=../lib/incident.sh
source "${ROOT_DIR}/lib/incident.sh"
# shellcheck source=../lib/analysis.sh
source "${ROOT_DIR}/lib/analysis.sh"
# shellcheck source=../lib/ioforensics.sh
source "${ROOT_DIR}/lib/ioforensics.sh"

usage() {
    cat <<'USAGE'
Usage: server-forensics COMMAND

Commands:
  --version         Print version information.
  --health          Print current timer, log, incident, and config status.
  --health-json     Print current health as JSON.
  --doctor          Validate config, permissions, dependencies, and systemd state.
  --latest          Print the newest lightweight sample, one field per line.
  --tail [N]        Print the last N lightweight samples (default 10).
  --incidents       List recorded incidents, newest first, with trigger reason.
  --last-incident   Print the summary of the most recent incident.
  --last-analysis   Print the auto-generated root-cause analysis of the latest incident.
  --offenders [ID]  Print the offending-processes tables (ranked by CPU and by
                    disk read+write) for incident ID, or the latest incident.
  --io [ID]         Print the full I/O attribution capture (pidstat, iostat, PSI,
                    diskstats, mounts, per-offender /proc detail) for an incident.
  --test-panic      Create and close a safe test incident without expensive diagnostics.
  --watch           Run one watcher cycle.
  --collect         Run one collector cycle.
  --help            Show this help.
USAGE
}

status_value() {
    local label="$1"
    local value="$2"
    printf '%-24s %s\n' "$label:" "$value"
}

systemctl_value() {
    local property="$1"
    local unit="$2"

    if command_exists systemctl; then
        systemctl show --property="$property" --value "$unit" 2>/dev/null || printf 'unknown\n'
    else
        printf 'systemctl unavailable\n'
    fi
}

latest_incident() {
    find "$INCIDENT_DIR" -mindepth 1 -maxdepth 1 -type d -name 'incident-*' 2>/dev/null | sort | tail -n 1
}

cmd_version() {
    printf 'name=server-forensics\n'
    printf 'version=%s\n' "$SERVER_FORENSICS_VERSION"
    printf 'install_dir=%s\n' "$ROOT_DIR"
    printf 'config=%s\n' "${SF_CONFIG:-/etc/server-forensics/config.conf}"
}

cmd_health() {
    local last_line last_incident active_incident

    last_line="$(tail -n 1 "$CURRENT_LOG" 2>/dev/null || true)"
    active_incident="$(incident_active_dir 2>/dev/null || true)"
    last_incident="$(latest_incident)"

    cmd_version
    status_value "timer-active" "$(systemctl_value ActiveState server-forensics.timer)"
    status_value "service-active" "$(systemctl_value ActiveState server-forensics.service)"
    status_value "timer-next" "$(systemctl_value NextElapseUSecRealtime server-forensics.timer)"
    status_value "log-dir" "$LOG_DIR"
    status_value "current-log" "$CURRENT_LOG"
    status_value "last-run" "$(metric_value "$last_line" timestamp)"
    status_value "active-incident" "${active_incident:-none}"
    status_value "last-incident" "${last_incident:-none}"
    status_value "load-threshold" "$LOAD_THRESHOLD"
    status_value "lsphp-threshold" "$LSPHP_THRESHOLD"
    status_value "memory-threshold-mb" "$MEMORY_THRESHOLD_MB"
    status_value "established-threshold" "$ESTABLISHED_THRESHOLD"
    status_value "dstate-threshold" "$DSTATE_THRESHOLD"
    status_value "panic-cooldown" "$PANIC_COOLDOWN"
    status_value "keep-incidents" "$KEEP_INCIDENTS"
    status_value "plugins-enabled" "$ENABLE_PLUGINS"
    status_value "plugin-dirs" "$PLUGIN_DIRS"
}

json_escape() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    printf '%s' "$value"
}

json_pair() {
    local key="$1"
    local value="$2"
    local suffix=","
    if [[ "$#" -ge 3 ]]; then
        suffix="$3"
    fi
    printf '  "%s": "%s"%s\n' "$(json_escape "$key")" "$(json_escape "$value")" "$suffix"
}

cmd_health_json() {
    local last_line last_incident active_incident

    last_line="$(tail -n 1 "$CURRENT_LOG" 2>/dev/null || true)"
    active_incident="$(incident_active_dir 2>/dev/null || true)"
    last_incident="$(latest_incident)"

    printf '{\n'
    json_pair "name" "server-forensics"
    json_pair "version" "$SERVER_FORENSICS_VERSION"
    json_pair "timer_active" "$(systemctl_value ActiveState server-forensics.timer)"
    json_pair "service_active" "$(systemctl_value ActiveState server-forensics.service)"
    json_pair "log_dir" "$LOG_DIR"
    json_pair "current_log" "$CURRENT_LOG"
    json_pair "last_run" "$(metric_value "$last_line" timestamp)"
    json_pair "active_incident" "${active_incident:-none}"
    json_pair "last_incident" "${last_incident:-none}"
    json_pair "load_threshold" "$LOAD_THRESHOLD"
    json_pair "lsphp_threshold" "$LSPHP_THRESHOLD"
    json_pair "memory_threshold_mb" "$MEMORY_THRESHOLD_MB"
    json_pair "established_threshold" "$ESTABLISHED_THRESHOLD"
    json_pair "dstate_threshold" "$DSTATE_THRESHOLD"
    json_pair "plugins_enabled" "$ENABLE_PLUGINS"
    json_pair "plugin_dirs" "$PLUGIN_DIRS" ""
    printf '}\n'
}

check_command() {
    local name="$1"
    if command_exists "$name"; then
        printf 'OK   command: %s\n' "$name"
    else
        printf 'WARN command missing: %s\n' "$name"
    fi
}

check_writable_dir() {
    local dir="$1"
    if [[ -d "$dir" && -w "$dir" ]]; then
        printf 'OK   writable: %s\n' "$dir"
    else
        printf 'FAIL not writable: %s\n' "$dir"
        return 1
    fi
}

cmd_doctor() {
    local failures=0

    printf 'server-forensics doctor\n'
    printf 'version=%s\n' "$SERVER_FORENSICS_VERSION"
    printf 'config=ok\n'

    check_writable_dir "$LOG_DIR" || failures=$((failures + 1))
    check_writable_dir "$INCIDENT_DIR" || failures=$((failures + 1))
    check_writable_dir "$ARCHIVE_DIR" || failures=$((failures + 1))
    check_writable_dir "$STATE_DIR" || failures=$((failures + 1))

    check_command bash
    check_command awk
    check_command ps
    check_command pstree
    check_command crontab
    check_command find
    check_command sort
    check_command head
    check_command timeout
    check_command mysqladmin
    check_command exim
    check_command ss
    check_command lsof
    check_command vmstat
    check_command iostat
    check_command pidstat
    check_command findmnt
    check_command journalctl
    check_command apachectl

    if command_exists systemctl; then
        printf 'OK   systemctl available\n'
        printf 'INFO timer-active=%s\n' "$(systemctl_value ActiveState server-forensics.timer)"
        printf 'INFO service-exec=%s\n' "$(systemctl_value ExecStart server-forensics.service)"
    else
        printf 'WARN systemctl unavailable\n'
    fi

    # Per-process I/O attribution is the difference between naming a service and
    # naming the process that moved the bytes, so its prerequisites are checked
    # explicitly rather than left to fail silently mid-incident.
    if sf_bool "${ENABLE_IO_FORENSICS:-1}"; then
        if command_exists pidstat; then
            printf 'OK   io-attribution: pidstat present\n'
        else
            printf 'WARN io-attribution: pidstat missing — install sysstat (dnf install sysstat)\n'
        fi
        if [[ "$(id -u 2>/dev/null || printf 1)" -eq 0 ]]; then
            printf 'OK   io-attribution: running as root (/proc/<pid>/io readable)\n'
        else
            printf 'WARN io-attribution: not root — /proc/<pid>/io and wchan will be restricted\n'
        fi
        if [[ -d /proc/pressure ]]; then
            printf 'OK   io-attribution: PSI available\n'
        else
            printf 'WARN io-attribution: /proc/pressure missing (kernel lacks CONFIG_PSI)\n'
        fi
        printf 'INFO io-attribution: window=%ss (%s x %ss), offender threshold=%s%%\n' \
            "$((PANIC_IO_SAMPLES * PANIC_IO_INTERVAL))" \
            "$PANIC_IO_SAMPLES" "$PANIC_IO_INTERVAL" "$PANIC_IO_OFFENDER_PCT"
    else
        printf 'INFO io-attribution disabled (ENABLE_IO_FORENSICS=0)\n'
    fi

    if [[ "$failures" -gt 0 ]]; then
        printf 'doctor=fail failures=%s\n' "$failures"
        return 1
    fi

    printf 'doctor=ok\n'
}

cmd_latest() {
    local line
    line="$(tail -n 1 "$CURRENT_LOG" 2>/dev/null || true)"

    if [[ -z "$line" ]]; then
        printf 'no samples recorded yet at %s\n' "$CURRENT_LOG" >&2
        return 1
    fi

    printf '%s\n' "$line" | tr ' ' '\n'
}

cmd_tail() {
    local count="${1:-10}"

    if ! is_uint "$count"; then
        printf 'tail count must be a non-negative integer: %s\n' "$count" >&2
        return 2
    fi

    if [[ ! -r "$CURRENT_LOG" ]]; then
        printf 'no current log at %s\n' "$CURRENT_LOG" >&2
        return 1
    fi

    tail -n "$count" "$CURRENT_LOG"
}

cmd_incidents() {
    local dir found=0

    while IFS= read -r dir; do
        [[ -n "$dir" ]] || continue
        found=1
        printf '%-28s reason=%s\n' "$(basename "$dir")" "$(incident_meta_get "$dir" reason unknown)"
    done < <(find "$INCIDENT_DIR" -mindepth 1 -maxdepth 1 -type d -name 'incident-*' 2>/dev/null | sort -r)

    if [[ "$found" -eq 0 ]]; then
        printf 'no incidents recorded\n'
    fi
}

cmd_last_incident() {
    local dir
    dir="$(latest_incident)"

    if [[ -z "$dir" ]]; then
        printf 'no incidents recorded\n'
        return 0
    fi

    printf 'incident-dir=%s\n\n' "$dir"

    if [[ -r "${dir}/summary.txt" ]]; then
        cat "${dir}/summary.txt"
    else
        printf 'summary.txt not found (incident may still be active)\n'
    fi
}

cmd_last_analysis() {
    local dir
    dir="$(latest_incident)"

    if [[ -z "$dir" ]]; then
        printf 'no incidents recorded\n'
        return 0
    fi

    printf 'incident-dir=%s\n\n' "$dir"

    if [[ -r "${dir}/analysis.txt" ]]; then
        cat "${dir}/analysis.txt"
        return 0
    fi

    # No analysis on disk (e.g. an incident that is still active, or one closed
    # before this feature existed). Generate a best-effort view on demand.
    if incident_active_dir >/dev/null 2>&1 && [[ "$(incident_active_dir 2>/dev/null)" == "$dir" ]]; then
        printf 'analysis.txt not found (incident still active); showing interim analysis:\n\n'
    else
        printf 'analysis.txt not found; generating from captured evidence:\n\n'
    fi

    analysis_generate "$dir" >/dev/null
    cat "${dir}/analysis.txt" 2>/dev/null || printf 'unable to generate analysis\n'
}

# Resolves an incident argument to a directory: an incident id, a bare
# timestamp, or empty for the newest incident.
resolve_incident() {
    local wanted="${1:-}"

    if [[ -z "$wanted" ]]; then
        latest_incident
        return 0
    fi

    local dir="${INCIDENT_DIR}/${wanted}"
    [[ -d "$dir" ]] || dir="${INCIDENT_DIR}/incident-${wanted}"
    if [[ ! -d "$dir" ]]; then
        printf 'no such incident: %s\n' "$wanted" >&2
        return 1
    fi

    printf '%s\n' "$dir"
}

# The answer to "which process was actually consuming I/O" — the incident-level
# table, merged across every snapshot and ranked by peak observed throughput.
cmd_offenders() {
    local dir tsv
    dir="$(resolve_incident "${1:-}")" || return 1

    if [[ -z "$dir" ]]; then
        printf 'no incidents recorded\n'
        return 0
    fi

    printf 'incident-dir=%s\n' "$dir"
    printf 'reason=%s\n\n' "$(incident_meta_get "$dir" reason unknown)"

    local cputsv
    tsv="$(io_aggregate_offenders "$dir")"
    cputsv="$(io_aggregate_cpu "$dir")"

    if [[ -z "$tsv" && -z "$cputsv" ]]; then
        printf 'No per-process attribution data captured for this incident.\n\n'
        printf 'Likely causes:\n'
        printf '  - the incident predates resource attribution (no offenders-*.tsv present)\n'
        printf '  - sysstat is not installed (pidstat missing) — run --doctor\n'
        printf '  - ENABLE_IO_FORENSICS=0 in the config\n'
        return 0
    fi

    # CPU first: most spikes on this box are compute-bound, and reading the CPU
    # table first stops a quiet disk from looking like the whole story.
    printf -- '-- Ranked by CPU --\n'
    printf '%s\n' "$cputsv" | io_render_stream cpu
    printf '\nPeak single-process CPU this incident: %s%% (pid %s, %s)\n\n' \
        "$(incident_meta_get "$dir" peak_cpu_pct 0)" \
        "$(incident_meta_get "$dir" peak_cpu_pid unknown)" \
        "$(incident_meta_get "$dir" peak_cpu_comm unknown)"

    printf -- '-- Ranked by disk read+write --\n'
    printf '%s\n' "$tsv" | io_render_stream io
    printf '\nPeak single-process I/O this incident: %s kB/s (pid %s, %s)\n' \
        "$(incident_meta_get "$dir" peak_io_kbs 0)" \
        "$(incident_meta_get "$dir" peak_io_pid unknown)" \
        "$(incident_meta_get "$dir" peak_io_comm unknown)"

    printf '\nFull capture (cmdline, cwd, open files, /proc/PID/io): %s --io %s\n' \
        "$(basename "$0")" "$(basename "$dir")"
}

# Dumps the raw I/O attribution captures for an incident, newest snapshot last.
cmd_io() {
    local dir
    dir="$(resolve_incident "${1:-}")" || return 1

    if [[ -z "$dir" ]]; then
        printf 'no incidents recorded\n'
        return 0
    fi

    local -a logs=()
    mapfile -t logs < <(find "$dir" -maxdepth 1 -type f -name 'io-*.log' 2>/dev/null | sort -V)

    if [[ "${#logs[@]}" -eq 0 ]]; then
        printf 'no I/O attribution captures in %s\n' "$dir" >&2
        return 1
    fi

    cat "${logs[@]}"
}

cmd_test_panic() {
    "${ROOT_DIR}/scripts/panic.sh" --test-panic
}

main() {
    case "${1:---help}" in
        --version)
            cmd_version
            ;;
        --health)
            cmd_health
            ;;
        --health-json)
            cmd_health_json
            ;;
        --doctor)
            cmd_doctor
            ;;
        --latest)
            cmd_latest
            ;;
        --tail)
            cmd_tail "${2:-10}"
            ;;
        --incidents)
            cmd_incidents
            ;;
        --last-incident)
            cmd_last_incident
            ;;
        --last-analysis)
            cmd_last_analysis
            ;;
        --offenders)
            cmd_offenders "${2:-}"
            ;;
        --io)
            cmd_io "${2:-}"
            ;;
        --test-panic)
            cmd_test_panic
            ;;
        --watch)
            "${ROOT_DIR}/scripts/watcher.sh"
            ;;
        --collect)
            "${ROOT_DIR}/scripts/collector.sh"
            ;;
        --help | -h)
            usage
            ;;
        *)
            usage >&2
            return 2
            ;;
    esac
}

main "$@"
